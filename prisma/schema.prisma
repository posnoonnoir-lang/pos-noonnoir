}

// ============================================================
// RESERVATION (Đặt bàn)
// ============================================================

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReservationSource {
  PHONE
  WALK_IN
  WEBSITE
  ZALO
}

model Reservation {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerName    String            @map("customer_name")
  customerPhone   String            @map("customer_phone")
  customerEmail   String?           @map("customer_email")
  guestCount      Int               @map("guest_count")
  tableId         String?           @map("table_id") @db.Uuid
  tableNumber     String?           @map("table_number")
  zonePreference  String?           @map("zone_preference")
  date            DateTime          @db.Date
  time            String
  status          ReservationStatus @default(PENDING)
  notes           String?
  specialRequests String?           @map("special_requests")
  source          ReservationSource @default(PHONE)
  staffId         String            @map("staff_id") @db.Uuid
  staffName       String            @map("staff_name")
  confirmedAt     DateTime?         @map("confirmed_at")
  seatedAt        DateTime?         @map("seated_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([date, status])
  @@map("reservation")
}

// ============================================================
// 86 / OUT OF STOCK (Operational)
// ============================================================

model Out86 {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String   @unique @map("product_id") @db.Uuid
  productName String   @map("product_name")
  reason      String?
  staffId     String   @map("staff_id") @db.Uuid
  staffName   String   @map("staff_name")
  markedAt    DateTime @default(now()) @map("marked_at")

  @@map("out_86")
}

// ============================================================
// PROMOTIONS & HAPPY HOUR
// ============================================================

enum PromoType {
  HAPPY_HOUR
  PERCENT_OFF
  COMBO
  FIXED_AMOUNT
}

enum PromoStatus {
  ACTIVE
  SCHEDULED
  EXPIRED
  DISABLED
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

model Promotion {
  id                   String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  description          String
  type                 PromoType
  status               PromoStatus @default(ACTIVE)
  discountPercent      Int?        @map("discount_percent")
  discountAmount       Decimal?    @map("discount_amount") @db.Decimal(12, 0)
  minOrderAmount       Decimal?    @map("min_order_amount") @db.Decimal(12, 0)
  maxDiscount          Decimal?    @map("max_discount") @db.Decimal(12, 0)
  applicableCategories String[]    @default([]) @map("applicable_categories")
  applicableProducts   String[]    @default([]) @map("applicable_products")
  startTime            String?     @map("start_time")
  endTime              String?     @map("end_time")
  activeDays           DayOfWeek[] @default([MON, TUE, WED, THU, FRI, SAT, SUN]) @map("active_days")
  startDate            DateTime    @map("start_date")
  endDate              DateTime?   @map("end_date")
  maxUsage             Int?        @map("max_usage")
  currentUsage         Int         @default(0) @map("current_usage")
  comboRequirement     String?     @map("combo_requirement")
  comboReward          String?     @map("combo_reward")
  priority             Int         @default(0)
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@map("promotion")
}

// ============================================================
// EQUIPMENT (CCDC) & DEPRECIATION
// ============================================================

enum EquipmentStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
  DAMAGED
}

model Equipment {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String
  code                   String          @unique
  category               String
  quantity               Int             @default(1)
  unitPrice              Decimal         @map("unit_price") @db.Decimal(12, 0)
  totalValue             Decimal         @map("total_value") @db.Decimal(12, 0)
  purchaseDate           DateTime        @map("purchase_date")
  poNumber               String?         @map("po_number")
  usefulLifeMonths       Int             @map("useful_life_months")
  monthlyDepreciation    Decimal         @map("monthly_depreciation") @db.Decimal(12, 0)
  accumulatedDepreciation Decimal        @default(0) @map("accumulated_depreciation") @db.Decimal(12, 0)
  netBookValue           Decimal         @map("net_book_value") @db.Decimal(12, 0)
  location               String
  status                 EquipmentStatus @default(ACTIVE)
  notes                  String?

  depreciationEntries DepreciationEntry[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("equipment")
}

model DepreciationEntry {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  equipmentId        String    @map("equipment_id") @db.Uuid
  equipment          Equipment @relation(fields: [equipmentId], references: [id])
  month              String
  amount             Decimal   @db.Decimal(12, 0)
  accumulatedBefore  Decimal   @map("accumulated_before") @db.Decimal(12, 0)
  accumulatedAfter   Decimal   @map("accumulated_after") @db.Decimal(12, 0)
  netBookValue       Decimal   @map("net_book_value") @db.Decimal(12, 0)
  createdAt          DateTime  @default(now()) @map("created_at")

  @@unique([equipmentId, month])
  @@map("depreciation_entry")
}

// ============================================================
// SYSTEM SETTINGS (Key-Value JSON store)
// ============================================================

model SystemSetting {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String   @unique
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_setting")
}
