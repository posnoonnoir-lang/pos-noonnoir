model NotificationConfig {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  staffId           String  @map("staff_id") @db.Uuid
  telegramChatId    String  @map("telegram_chat_id")
  alertVoid         Boolean @default(true) @map("alert_void")
  alertLowStock     Boolean @default(true) @map("alert_low_stock")
  alertShiftClose   Boolean @default(true) @map("alert_shift_close")
  alertCashVariance Boolean @default(true) @map("alert_cash_variance")
  alertOxidation    Boolean @default(true) @map("alert_oxidation")
  alertDailyPl      Boolean @default(true) @map("alert_daily_pl")
  quietStart        String  @default("00:00") @map("quiet_start")
  quietEnd          String  @default("07:00") @map("quiet_end")
  isActive          Boolean @default(true) @map("is_active")

  staff Staff @relation(fields: [staffId], references: [id])

  @@map("notification_config")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action    String
  tableName String   @map("table_name")
  recordId  String   @map("record_id") @db.Uuid
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  staffId   String?  @map("staff_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tableName, recordId])
  @@index([createdAt])
  @@map("audit_log")
}

// ============================================================
// SHIFT TARGET (V2 — Chỉ tiêu ca)
// ============================================================

model ShiftTarget {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shiftRecordId   String    @map("shift_record_id") @db.Uuid
  revenueTarget   Decimal   @default(0) @map("revenue_target") @db.Decimal(12, 2)
  orderTarget     Int       @default(0) @map("order_target")
  customerTarget  Int       @default(0) @map("customer_target")
  pushProducts    Json?     @map("push_products")
  suggestedBy     String    @default("SYSTEM") @map("suggested_by")
  approvedBy      String?   @map("approved_by") @db.Uuid
  approvedAt      DateTime? @map("approved_at")
  isApproved      Boolean   @default(false) @map("is_approved")
  actualRevenue   Decimal?  @map("actual_revenue") @db.Decimal(12, 2)
  actualOrders    Int?      @map("actual_orders")
  actualCustomers Int?      @map("actual_customers")
  actualPushSold  Json?     @map("actual_push_sold")
  evaluation      String?
  evaluatedAt     DateTime? @map("evaluated_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  shift ShiftRecord @relation(fields: [shiftRecordId], references: [id])

  @@index([shiftRecordId])
  @@map("shift_target")
