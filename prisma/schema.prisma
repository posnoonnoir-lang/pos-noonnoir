// ============================================================
// FORECAST (V2 — Dự báo đặt hàng)
// ============================================================

model ForecastConfig {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId      String   @unique @map("product_id") @db.Uuid
  avgWeeklySales Decimal  @default(0) @map("avg_weekly_sales") @db.Decimal(12, 3)
  seasonFactor   Decimal  @default(1.0) @map("season_factor") @db.Decimal(4, 2)
  trendFactor    Decimal  @default(1.0) @map("trend_factor") @db.Decimal(4, 2)
  leadTimeDays   Int      @default(3) @map("lead_time_days")
  safetyStock    Int      @default(5) @map("safety_stock")
  lastCalculated DateTime @default(now()) @map("last_calculated")

  @@map("forecast_config")
}

model ForecastSuggestion {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  productName     String   @map("product_name")
  currentStock    Decimal  @map("current_stock") @db.Decimal(12, 3)
  predictedDemand Decimal  @map("predicted_demand") @db.Decimal(12, 3)
  suggestedQty    Decimal  @map("suggested_qty") @db.Decimal(12, 3)
  confidence      Decimal  @default(0.7) @db.Decimal(3, 2)
  reason          String?
  status          String   @default("PENDING")
  weekOf          DateTime @map("week_of") @db.Date
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([status, weekOf])
  @@map("forecast_suggestion")
}

// ============================================================
// FEEDBACK (V2 — QR Feedback từ khách hàng)
// ============================================================

model FeedbackSession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  orderNo   String   @map("order_no")
  token     String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  items FeedbackItem[]

  @@map("feedback_session")
}

model FeedbackItem {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId   String    @map("session_id") @db.Uuid
  productId   String    @map("product_id") @db.Uuid
  productName String    @map("product_name")
  rating      Int?
  comment     String?
  submittedAt DateTime? @map("submitted_at")

  session FeedbackSession @relation(fields: [sessionId], references: [id])

